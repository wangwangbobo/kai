# Per-user configuration for Kai.
#
# Copy to users.yaml (or /etc/kai/users.yaml for protected
# installations) and customize. When this file exists, it replaces
# ALLOWED_USER_IDS as the authorization source.
#
# Admin-controlled fields live here. User-controlled preferences
# (active model, working budget) are managed via Telegram commands
# (/model, /budget) and stored in the database.

users:
  # - telegram_id: 123456789       # Required. Message @userinfobot to find yours.
  #   name: alice                   # Required. Display name for logs.
  #   role: admin                   # "admin" or "user" (default: "user").
  #   github: alice-dev             # GitHub username for webhook routing.
  #   os_user: alice                # OS account for subprocess isolation (Phase 3).
  #   home_workspace: /Users/alice/workspace  # Per-user home workspace.
  #   max_budget: 15.0              # Budget ceiling in USD.
